# --- Main stack (docker-compose.yml) ---
MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_DATABASE=linkedin_archive
MYSQL_USER=li_user
MYSQL_PASSWORD=change-me-app-password

# Required for token encryption in CMS config
APP_SECRET=change-me-64-hex-chars

# Optional Strapi integration
STRAPI_BASE_URL=
STRAPI_API_TOKEN=
STRAPI_CONTENT_TYPE=articles

# --- AI session stack (docker-compose.ai-session.yml) ---
AI_SESSION_POSTGRES_DB=ai_session
AI_SESSION_POSTGRES_USER=ai_session
AI_SESSION_POSTGRES_PASSWORD=change-me-ai-session-password

# Optional overrides
CHATGPT_SESSION_API_BASE=http://ai_session_gateway:8190
SESSION_TARGET_NAME=chatgpt
SESSION_LOGIN_URL=https://chatgpt.com/auth/login
SESSION_AUTH_CHECK_URL=https://chatgpt.com/
NOVNC_PUBLIC_URL=http://127.0.0.1:7790/vnc.html?autoconnect=1&resize=remote&reconnect=1
